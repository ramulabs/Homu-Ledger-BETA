<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>HOMU Ledger</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<!-- Locales the app is localised in. Bahasa Indonesia + English (US).
	     Apple uses this for App Store listing localisation discovery. -->
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>id</string>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<!-- Match the PWA manifest: portrait-primary on iPhone, all orientations on iPad. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!--
	  App Transport Security
	  ----------------------
	  Capacitor 8 defaults to denying arbitrary loads; we keep that. The only
	  HTTPS host the webview reaches is homu.ramu.app (+ Supabase auth callbacks
	  + Vercel preview URLs), all of which terminate in modern TLS, so no
	  NSExceptionDomains overrides are required. If a future plugin needs
	  WKWebsiteDataStore or http: for local dev, add a debug-only entry here.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>
	<!--
	  Universal Links
	  ---------------
	  Associated Domains entitlement is set in App.entitlements (see scripts/
	  native-ios-bootstrap.md). When the user taps https://homu.ramu.app/* the
	  OS will hand the URL to this app instead of Safari, *if* the
	  apple-app-site-association file is served from the host (we drop it at
	  /.well-known/apple-app-site-association — see public/.well-known/).
	-->
	<!--
	  Permissions used by plugins or web APIs. We list the minimum surface;
	  if a future feature (e.g. RAM-? receipt scan) needs camera/photos,
	  add the matching key here with a bilingual reason string.
	-->
	<key>NSCameraUsageDescription</key>
	<string>HOMU needs camera access to attach a receipt photo to a transaction. / HOMU memerlukan akses kamera untuk melampirkan foto struk ke transaksi.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>HOMU needs photo-library access to attach a receipt image to a transaction. / HOMU memerlukan akses pustaka foto untuk melampirkan gambar struk ke transaksi.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>HOMU uses the microphone for voice-to-transaction entry. / HOMU menggunakan mikrofon untuk pencatatan transaksi lewat suara.</string>
</dict>
</plist>
