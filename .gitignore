# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
# Subprojects (e.g. cloudflare/inbox-email-worker)
**/node_modules/
.wrangler/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude
.claude/settings.local.json

# supabase CLI working dir
supabase/.temp

# typescript
*.tsbuildinfo
next-env.d.ts

# native iOS (Capacitor) — see ios/.gitignore for the local one, this is
# an extra safety net at the repo root.
/ios/App/Pods/
/ios/App/build/
/ios/DerivedData/
/ios/App/App/public/
/ios/App/App/capacitor.config.json
/ios/App/App/config.xml
/ios/capacitor-cordova-ios-plugins/

# native Android (Bubblewrap-generated artefacts)
/android/app/build/
/android/build/
/android/.gradle/
/android/local.properties
/android/app/release/
/android/app/debug/
*.apk
*.aab
*.keystore
*.jks

